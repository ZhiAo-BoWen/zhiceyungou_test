# 复制为 .env 后填写真实配置（.env 已被 git 忽略，勿提交）
# cp .env.example .env

DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DEFAULT_MODEL=qwen3.7-plus
FLASK_SECRET_KEY=change-me
ADMIN_PASSWORD=admin123
DEFAULT_IP_QUOTA=2

# 部署模式：local（本地桌面，手动选文件夹）| server（Ubuntu 等服务端，自动分配工作空间）
DEPLOY_MODE=server
IP_WORKSPACE_QUOTA_BYTES=10485760
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
